# PDF Translator environment example
# Copy to the ignored .env for local development. Never commit a populated key.

# Local llama.cpp defaults. A local server normally requires no API key.
OPENAI_API_KEY=
OPENAI_API_BASE=http://localhost:8080/v1
OPENAI_MODEL=default_model

# For a cloud provider, set OPENAI_API_KEY at runtime (preferred) or only in
# your ignored .env, then replace the base and model above. For example:
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Web server asset override (normally unnecessary for source and Nix runs).
# STATIC_DIR=/absolute/path/to/static
